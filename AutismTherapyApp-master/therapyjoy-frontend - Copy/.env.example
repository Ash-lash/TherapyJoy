# TherapyJoy Frontend - Production Environment Variables
# Copy this file to .env.production and fill in your actual values

# ===== APPLICATION SETTINGS =====
NODE_ENV=production

# ===== API CONFIGURATION =====
# Where your backend server is deployed
# Example values:
#   Development: http://localhost:4001/api
#   Production: https://api.therapyjoy.com/api
#   Railway: https://therapyjoy-api.railway.app/api

REACT_APP_API_BASE=https://api.therapyjoy.com/api

# ===== FIREBASE SDK CONFIGURATION =====
# Get these from Firebase Console → Project Settings → Your apps
# Select your web app and get the SDK configuration

# Firebase API Key (public, used for client-side authentication)
# Example: AIzaSyA...
REACT_APP_FIREBASE_API_KEY=AIzaSyA...

# Firebase Auth Domain (where users will be redirected for sign-in)
# Example: therapyjoy-abc123.firebaseapp.com
REACT_APP_FIREBASE_AUTH_DOMAIN=therapyjoy-abc123.firebaseapp.com

# Firebase Project ID (same as backend FIREBASE_PROJECT_ID)
# Example: therapyjoy-abc123
REACT_APP_FIREBASE_PROJECT_ID=therapyjoy-abc123

# Firebase Storage Bucket (for storing files/images)
# Example: therapyjoy-abc123.appspot.com
REACT_APP_FIREBASE_STORAGE_BUCKET=therapyjoy-abc123.appspot.com

# Firebase Messaging Sender ID (for notifications)
# Example: 123456789012
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789012

# Firebase App ID (unique identifier for your web app)
# Example: 1:123456789012:web:abc123def456...
REACT_APP_FIREBASE_APP_ID=1:123456789012:web:abc123def456...

# ===== (OPTIONAL) ANALYTICS =====
# Google Analytics ID for tracking user behavior
# REACT_APP_GA_ID=G-xxxxx

# Sentry DSN for error tracking
# REACT_APP_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ===== (OPTIONAL) FEATURE FLAGS =====
# Enable/disable features during development
# REACT_APP_ENABLE_PAYMENTS=true
# REACT_APP_ENABLE_DOCTOR_CHAT=false

# ===== RAZORPAY =====
# Public key id used by the frontend checkout widget
REACT_APP_RAZORPAY_KEY_ID=rzp_test_your_public_key_id
